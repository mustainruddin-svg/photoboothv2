# Salin file ini menjadi ".env.local" untuk pengembangan lokal (otomatis
# di-gitignore, tidak akan ikut ter-commit ke GitHub).
#
# VITE_GAS_URL (opsional): URL Web App Google Apps Script yang sudah di-deploy.
# Jika diisi, aplikasi otomatis tersambung ke Google Drive tujuan saat pertama
# kali dibuka — operator tidak perlu menempelkan URL manual di tab Pengaturan.
# Jika dikosongkan / file ini tidak ada, aplikasi akan berjalan di Mode
# Simulasi sampai URL diisi manual lewat UI.
#
# PENTING: jangan pernah menaruh URL asli langsung di source code / commit
# ke GitHub. Untuk deployment produksi (Vercel/GitHub Pages), set variabel
# ini lewat dashboard/Secrets platform tersebut, bukan lewat file ini.
VITE_GAS_URL="https://script.google.com/macros/s/AKfycbwXXVRTez5Z6B6u0HAmMKLXgXeNBwiG_ncpUlugMhSJv5U_oY6NLJHKVsABC6C4Y0pE/exec"
